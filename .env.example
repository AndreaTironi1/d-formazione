# Copia questo file in .env.local e compila i valori reali.
# NON committare .env.local su Git.

# URL del deployment Convex (da: npx convex dev oppure dashboard.convex.dev)
VITE_CONVEX_URL=https://your-deployment.eu-west-1.convex.cloud

# Publishable key di Clerk (da: Clerk Dashboard → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Deployment Convex usato da npx convex dev (generato automaticamente)
CONVEX_DEPLOYMENT=dev:your-deployment
